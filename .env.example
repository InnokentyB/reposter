APP_ENV=dev
LOG_LEVEL=INFO
DATABASE_PATH=var/repost-bot.sqlite3
THREADS_ENABLED=false

TELEGRAM_CHANNEL_ID=tg-channel-1
# Optional multi-source mode:
# TELEGRAM_CHANNEL_IDS=tg-channel-1,tg-channel-2
TELEGRAM_BOT_TOKEN=replace-me
TELEGRAM_POLL_TIMEOUT_SECONDS=30
TELEGRAM_POLL_INTERVAL_SECONDS=2
DELIVERY_BATCH_LIMIT=100
MEDIA_STORAGE_PATH=var/media
# Required for Threads media publishing:
# MEDIA_BASE_URL=https://your-domain.example/repost-media

VK_COMMUNITY_ID=12345
VK_ACCESS_TOKEN=replace-me

OK_GROUP_ID=ok-group-1
OK_ACCESS_TOKEN=replace-me

THREADS_ACCOUNT_ID=threads-account-1
THREADS_ACCESS_TOKEN=replace-me

ALLOWED_OPERATORS=allowed-operator
